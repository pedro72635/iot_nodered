<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:IOT_luces_pedro_MAUI.ViewModels"
             x:Class="IOT_luces_pedro_MAUI.MainPage"
             xmlns:converters="clr-namespace:IOT_luces_pedro_MAUI.Converters"
             BackgroundColor="#121212">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:RoleToColorConverter x:Key="RoleToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Header -->
        <Frame Grid.Row="0" BackgroundColor="#1E1E1E" CornerRadius="15" Padding="15" HasShadow="True" BorderColor="#333333">
            <StackLayout Orientation="Horizontal" Spacing="15">
                <Ellipse WidthRequest="15" HeightRequest="15" Fill="#00FF7F" VerticalOptions="Center"/>
                <Label Text="Sistema de Control IoT" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
            </StackLayout>
        </Frame>

        <!-- Chat Area -->
        <CollectionView Grid.Row="1" Margin="0,20,0,20" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout Margin="0,5">
                        <Frame BackgroundColor="{Binding Role, Converter={StaticResource RoleToColorConverter}}"
                               CornerRadius="10" Padding="15" HasShadow="False" BorderColor="#2C2C2C">
                            <StackLayout>
                                <Label Text="{Binding Role}" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold" TextTransform="Uppercase" Margin="0,0,0,5" />
                                <Label Text="{Binding Content}" TextColor="White" FontSize="14" />
                            </StackLayout>
                        </Frame>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input Area -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" ColumnSpacing="15">
            <Frame Grid.Column="0" BackgroundColor="#1E1E1E" CornerRadius="25" Padding="20,5" HasShadow="False" BorderColor="#333333">
                <Entry Placeholder="Escribe un comando (ej. 'enciende la luz roja')..."
                       Text="{Binding UserInput}"
                       TextColor="White"
                       PlaceholderColor="#888888"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center" 
                       ReturnCommand="{Binding SendCommand}" />
            </Frame>
            <Button Grid.Column="1" 
                    Text="Enviar" 
                    Command="{Binding SendCommand}" 
                    BackgroundColor="#007ACC" 
                    TextColor="White" 
                    CornerRadius="25"
                    Padding="25, 0"
                    FontAttributes="Bold"/>
        </Grid>

        <!-- Loading overlay -->
        <ActivityIndicator Grid.RowSpan="3" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#007ACC" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="50" HeightRequest="50" />
    </Grid>
</ContentPage>
